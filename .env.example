DATABASE_URL="postgresql://user:password@localhost:5432/ledgeradb"
PORT=4000
JWT_SECRET=your_jwt_secret_key_here
PHANTOM_DETECTION_THRESHOLD=0.2
NODE_ENV=development

# ----------------------------
# Twilio (Call/Call tracking)
# ----------------------------
# Used to validate incoming Twilio webhook requests (Voice status callbacks, etc.)
# The webhook validator requires this exact variable name:
TWILIO_AUTH_TOKEN=""

# Optional (may be used elsewhere for REST API usage)
TWILIO_ACCOUNT_SID=""
TWILIO_API_KEY=""
TWILIO_API_SECRET=""
# ----------------------------
# BigQuery (DWH export)
# ----------------------------
# If these are not set (projectId/datasetId), BigQuery export will be skipped.
BQ_PROJECT_ID=""
BQ_DATASET_ID=""

# Optional:
# Path to a service account JSON file.
# If omitted, BigQuery SDK will use default credentials.
BQ_SERVICE_ACCOUNT_KEY_PATH=""

# ----------------------------
# Database Backups (Audit)
# ----------------------------
# Directory where pg_dump files are written.
BACKUP_DIR="./backups"

# Retention window in days. Audit requires retention of exactly 30 days.
BACKUP_RETENTION_DAYS=30

# Daily backup schedule (node-cron format). Default: 10 2 * * *
BACKUP_CRON_SCHEDULE="10 2 * * *"

# Optional: override which specific backup file to use for the restore test.
# Leave empty to use the latest backup.
BACKUP_RESTORE_TEST_BACKUP_FILENAME=""

# Optional: temp DB name prefix for restore test.
BACKUP_RESTORE_TEST_TEMP_DB_PREFIX="ledgera_restore_test_"

# Restore-test validation: comma-separated list of expected Prisma model tables.
# These are mapped case-insensitively to the restored database's actual table names.
BACKUP_RESTORE_VALIDATION_TABLES="Company,Job,Payment,Contract,Invoice"

# Restore-test validation: minimum row count per table.
# Use 0 to only require successful restore + table existence.
BACKUP_RESTORE_MIN_ROWS=0

# ----------------------------
# Restore Test (Audit)
# ----------------------------
# Enable/disable automated restore-test cron.
BACKUP_RESTORE_TEST_ENABLED="true"

# Automated restore-test schedule (node-cron format). Audit requires monthly testing.
# Default: 30 3 1 * * (03:30 on the 1st of every month)
BACKUP_RESTORE_TEST_CRON_SCHEDULE="30 3 1 * *"

# ----------------------------
# pg binary resolution (optional)
# ----------------------------
# If pg_dump/pg_restore/createdb/dropdb/psql are not on PATH,
# set this to the folder containing those executables, e.g.:
# BACKUP_PG_BIN_DIR="/c/Program Files/PostgreSQL/16/bin"
BACKUP_PG_BIN_DIR=""
